<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ipc.project.UserCreationController">
    <children>
        <Label text="Creación de usuario" />
      <VBox prefHeight="0.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nombre" />
            <TextField fx:id="Nombre" promptText="Don_juan7" />
         </children>
      </VBox>
      <VBox prefHeight="0.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Correo" />
            <TextField fx:id="Correo" promptText="example@upv.edu.es" />
         </children>
      </VBox>
      <VBox prefHeight="30.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña" />
            <TextField fx:id="Passworten" />
         </children>
      </VBox>
        <Button fx:id="secondaryButton" onAction="#switchToLogin" prefHeight="26.0" prefWidth="116.0" text="Crear cuenta" />
      <HBox alignment="TOP_CENTER" prefHeight="24.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ya tienes una cuenta?" />
            <Hyperlink onAction="#switchToLogin" text="Log in" />
         </children>
      </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
