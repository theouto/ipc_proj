<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="325.0" prefWidth="327.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ipc.project.UserCreationController">
    <children>
        <Label text="Registro">
         <font>
            <Font size="27.0" />
         </font></Label>
      <VBox prefHeight="0.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Nombre">
               <font>
                  <Font size="18.0" />
               </font></Text>
            <TextField fx:id="Nombre" promptText="tu_nick">
               <font>
                  <Font size="16.0" />
               </font></TextField>
         </children>
      </VBox>
      <VBox prefHeight="0.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Correo">
               <font>
                  <Font size="18.0" />
               </font></Text>
            <TextField fx:id="Correo" promptText="nombre@upv.edu.es">
               <font>
                  <Font size="16.0" />
               </font></TextField>
         </children>
      </VBox>
      <VBox prefHeight="30.0" prefWidth="202.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña">
               <font>
                  <Font size="18.0" />
               </font></Text>
            <TextField fx:id="Passworten">
               <font>
                  <Font size="16.0" />
               </font></TextField>
         </children>
      </VBox>
        <Button fx:id="secondaryButton" onAction="#switchToLogin" prefHeight="35.0" prefWidth="165.0" text="Crear cuenta">
         <font>
            <Font size="17.0" />
         </font></Button>
      <HBox alignment="CENTER" prefHeight="25.0" prefWidth="357.0" spacing="10.0" style="fx-padding: 10px;">
         <children>
            <Label text="¿Ya tienes una cuenta?" />
            <Hyperlink onMouseClicked="#switchToLogin" text="Haz clic aquí" />
         </children>
      </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
