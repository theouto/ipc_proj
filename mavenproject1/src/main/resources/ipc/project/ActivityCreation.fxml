<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="550.0" spacing="25.0" styleClass="main-background" stylesheets="@resources/history.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ipc.project.ActivityCreationController">
   <children>
      <Label styleClass="title-label" text="Importar Actividad" />
      
      <VBox alignment="CENTER_LEFT" maxWidth="400.0" spacing="20.0" styleClass="form-container">
         <children>
            
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="field-label" text="Nombre de la ruta" />
                  <TextField fx:id="ActivityName" promptText="Ej: Trail por la Calderona" styleClass="input-field" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="field-label" text="Archivo GPX" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label fx:id="filePath" maxWidth="Infinity" styleClass="text-secondary" text="Ningún archivo seleccionado..." HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#gpxImport" styleClass="btn-secondary" text="Examinar..." />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
         </children>
      </VBox>
      
      <HBox alignment="CENTER" maxWidth="400.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#back" styleClass="btn-secondary" text="Cancelar" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="primaryButton" mnemonicParsing="false" onAction="#ImportActivity" styleClass="btn-primary" text="Importar Ruta" />
         </children>
      </HBox>
      
   </children>
   
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>